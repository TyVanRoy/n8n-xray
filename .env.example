# ── n8n Instance (Phase 1: Export) ────────────────────────────
N8N_API_KEY=your-n8n-api-key
N8N_BASE_URL=https://your-n8n-instance.com   # default: http://localhost:5678

# ── Anthropic (Phase 3: LLM Analysis, Phase 4: Synthesis) ───
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6             # default: claude-sonnet-4-6

# ── Optional tuning ─────────────────────────────────────────
# CONCURRENCY=5                               # parallel LLM requests (default: 5 for phase 3, 3 for phase 4)
# OUTPUT_DIR=./output                         # root output directory (default: ./output)
