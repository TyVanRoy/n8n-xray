# ── n8n Instance (Export) ─────────────────────────────────────
N8N_API_KEY=your-n8n-api-key
N8N_BASE_URL=https://your-n8n-instance.com   # default: http://localhost:5678

# ── Anthropic ────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_ANALYZE_MODEL=claude-sonnet-4-6    # model for per-workflow analysis (default: claude-sonnet-4-6)
ANTHROPIC_SYNTHESIS_MODEL=claude-sonnet-4-6  # model for system-level synthesis (default: claude-sonnet-4-6)

# ── Optional tuning ─────────────────────────────────────────
# CONCURRENCY=5                               # parallel LLM requests (default: 5 for analyze, 3 for synthesize)
# OUTPUT_DIR=./output                         # root output directory (default: ./output)
